# This repo commits `.env.development` (dev ALB) and `.env.production` (prod ALB).
# Override locally with `.env.local` (gitignored) — it wins over those files.

# --- API base ---
# `npm run dev` loads `.env.development` → dev ALB.
# `next build` / `next start` loads `.env.production` → prod ALB.
# Primary variable (no trailing slash):
# NEXT_PUBLIC_API_BASE_URL=http://aira-dev-alb-1200955087.eu-west-1.elb.amazonaws.com
#
# Legacy alias (still supported if NEXT_PUBLIC_API_BASE_URL is unset):
# NEXT_PUBLIC_TRIAGE_API_BASE=http://127.0.0.1:8000

# Local API default when neither variable is set: http://127.0.0.1:8000
# Docker Compose API on host:
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:18080

# --- Optional tuning ---
# POST /triage timeout (ms). LLM + RAG can exceed 60s on cold start.
# NEXT_PUBLIC_TRIAGE_TIMEOUT_MS=180000
# NEXT_PUBLIC_FEEDBACK_TIMEOUT_MS=45000

# Link RB-* tokens in action text to markdown files (e.g. GitHub blob URL to data/runbooks).
# NEXT_PUBLIC_RUNBOOK_DOCS_BASE=https://github.com/your-org/your-repo/blob/main/data/runbooks
