# Copy this file to `.env` in the same directory and fill in values.
# Never commit `.env`. Never put real keys in `.env.example` (this file is for Git).

# --- LLM / embeddings (RAG build-index and future agent) ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: OpenAI-compatible API base (e.g. OpenRouter for chat; embeddings often still use OpenAI)
# OPENAI_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_MODEL=text-embedding-3-small
RAG_INDEX_DIR=.rag_index

# Phase 4 triage (chat; OpenAI-compatible)
LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.2
# RAG_TOP_K=8

# Phase 5 API (`uv run serve-api`)
# API_HOST=127.0.0.1
# API_PORT=8000

# Phase 7 Gradio UI at /ui (install: uv sync --extra ui). Set 0 to disable mount.
# ENABLE_GRADIO_UI=1

# Phase 9 — full stack: docker compose up -d --build (API + n8n; see docker-compose.yml)
# Docker Compose publishes the API on host 18080 by default (avoids clashing with local :8000).
# COMPOSE_API_PORT=18080
# To use host port 8000 instead: COMPOSE_API_PORT=8000

# E2E script scripts/e2e_stack_check.sh (optional)
# API_BASE=http://127.0.0.1:18080
# STRICT_RAG_EVIDENCE=1
# SKIP_N8N=1
# SKIP_TRIAGE=1
# Phase 6 — n8n only: docker compose -f docker-compose.n8n.yml
# Docker Compose reads THIS repo-root .env for ${VAR} substitution (do not commit real URLs).
# After editing .env, recreate n8n: docker compose -f docker-compose.n8n.yml up -d --force-recreate
SLACK_WEBHOOK_URL=
# TRIAGE_API_BASE=http://host.docker.internal:8000
# N8N_WORKFLOW_LOG_DISABLE=1
# N8N_WORKFLOW_LOG_JSONL=/custom/n8n_events.jsonl
# N8N_TRIAGE_FEEDBACK_DISABLE=1
# N8N_TRIAGE_FEEDBACK_JSONL=/custom/triage_feedback.jsonl

# Append each POST /triage request+response to JSONL (default: data/logs/triage_outputs.jsonl)
# TRIAGE_AUDIT_DISABLE=1
# TRIAGE_AUDIT_JSONL=/path/to/custom.jsonl
# Cap stored RAG text size (characters); 0 = no truncation
# TRIAGE_AUDIT_MAX_RAG_CHARS=200000

# --- AWS (Terraform CLI / aws CLI — not auto-loaded by Terraform) ---
# Terraform does not read this file. Export these (or use AWS_PROFILE) before
# `terraform` in infra/terraform/envs/{dev,prod}. Name must be AWS_ACCESS_KEY_ID (not WS_).
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional integrations ---
VECTOR_DB_API_KEY=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ANTHROPIC_API_KEY=
