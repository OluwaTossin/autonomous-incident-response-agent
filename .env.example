# Copy to .env and fill in values. Never commit .env.

# --- LLM (required for agent phases) ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# When using the OpenAI client against OpenRouter, set the base URL (uncomment in app config when wired):
# OPENAI_API_BASE=https://openrouter.ai/api/v1

# --- AWS (when you provision infra / deploy) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional integrations ---
SLACK_WEBHOOK_URL=
VECTOR_DB_API_KEY=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ANTHROPIC_API_KEY=
