        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ summary: $json.body.incident_summary || 'Incident', description: JSON.stringify($json.body.recommended_actions || []) }) }}",
        "options": {}
      },
      "id": "http-jira",
      "name": "Mock Jira create",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, action: 'ticket_created', ticket: $json.key, jira: $json }) }}",
        "options": {}
      },
      "id": "respond-ticket",
      "name": "Respond With Ticket",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, action: 'not_escalated', ticket: null }) }}",
        "options": {}
      },
      "id": "respond-no-ticket",
      "name": "Respond No Ticket",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [680, 420]
    }
  ],
  "connections": {
