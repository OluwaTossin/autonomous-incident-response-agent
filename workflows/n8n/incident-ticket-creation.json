            "version": 2
          },
          "conditions": [
            {
              "id": "esc",
              "leftValue": "={{ $json.body.escalate }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-escalate",
      "name": "Should escalate",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
